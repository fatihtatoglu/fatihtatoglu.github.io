{{#listing.hasItems}}
  {{#listing.hasPagination}}
  <nav class="pagination" aria-label="{{i18n.ui.pagination.previous}} / {{i18n.ui.pagination.next}}">
    {{#listing}}
      {{#hasPrev}}
      <a
        class="btn btn--sm btn--quarter btn--tone-brand btn--icon-left"
        href="{{prevUrl}}"
        data-metric
        data-metric-name="pagination_click"
        data-metric-source="listing"
        data-metric-meta-direction="prev"
        rel="prev"
      >
        <svg aria-hidden="true">
          <use href="/assets/svg/icons.svg#icon-arrow-left"></use>
        </svg>
        <span>{{i18n.ui.pagination.previous}}</span>
      </a>
      {{/hasPrev}}
      {{^hasPrev}}
      <span
        class="btn btn--sm btn--quarter btn--tone-neutral btn--icon-left"
        aria-disabled="true"
      >
        <svg aria-hidden="true">
          <use href="/assets/svg/icons.svg#icon-arrow-left"></use>
        </svg>
        <span>{{i18n.ui.pagination.previous}}</span>
      </span>
      {{/hasPrev}}

      {{#hasNext}}
      <a
        class="btn btn--sm btn--quarter btn--tone-brand btn--icon-right"
        href="{{nextUrl}}"
        data-metric
        data-metric-name="pagination_click"
        data-metric-source="listing"
        data-metric-meta-direction="next"
        rel="next"
      >
        <span>{{i18n.ui.pagination.next}}</span>
        <svg aria-hidden="true">
          <use href="/assets/svg/icons.svg#icon-arrow-right"></use>
        </svg>
      </a>
      {{/hasNext}}
      {{^hasNext}}
      <span
        class="btn btn--sm btn--quarter btn--tone-neutral btn--icon-right"
        aria-disabled="true"
      >
        <span>{{i18n.ui.pagination.next}}</span>
        <svg aria-hidden="true">
          <use href="/assets/svg/icons.svg#icon-arrow-right"></use>
        </svg>
      </span>
      {{/hasNext}}
    {{/listing}}
  </nav>
  {{/listing.hasPagination}}
{{/listing.hasItems}}
